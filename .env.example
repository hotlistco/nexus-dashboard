# --- server ---
PORT=8787

# Weather: use lat/lon for the TV's home location
OPENWEATHER_API_KEY=
WEATHER_LAT=42.7648
WEATHER_LON=-71.4676
WEATHER_LABEL=Hudson, NH

# News
GNEWS_API_KEY=
NEWS_COUNTRY=us
NEWS_LANG=en
NEWS_TOPIC=technology

# Stocks
ALPHAVANTAGE_API_KEY=
STOCK_SYMBOLS=AAPL,MSFT,NVDA,AMZN,GOOGL,TSLA

# Trends
# Preferred if you have Google Trends API alpha access:
GOOGLE_TRENDS_API_URL=
GOOGLE_TRENDS_API_KEY=
# Fallback:
SERPAPI_API_KEY=
TRENDS_GEO=US

# Google Tasks backend auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost
GOOGLE_REFRESH_TOKEN=
GOOGLE_TASKS_LIST=My Tasks

# --- client ---
# Put this in client/.env.local for development
# VITE_API_BASE_URL=http://localhost:8787/api
