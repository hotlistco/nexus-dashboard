<?xml version="1.0" encoding="UTF-8"?>
<widget xmlns="http://www.w3.org/ns/widgets"
        xmlns:tizen="http://tizen.org/ns/widgets"
        id="http://hotlistco.com/NexusDashboard"
        version="1.0.0"
        viewmodes="maximized">
    <tizen:application id="Nexus12345.NexusDashboard" package="Nexus12345" required_version="4.0" />
    <!-- package is BingWallpr because reusing the certificate that was created, and it has to match - lazy -->
    <description>Nexus Dashboard - pulls together all your relevant up-to-date information live</description>
    <content src="index.html" />
    <icon src="icon.png" />
    <name>NexusDashboard</name>
    <!-- feature name="http://tizen.org/feature/screen.size.all" -->
    <feature name="http://tizen.org/feature/screen.size.normal.1080.1920"/>
    <tizen:metadata key="http://tizen.org/metadata/app_ui_type/base_screen_resolution" value="extensive"/>
    <feature name="http://tizen.org/feature/tv.inputdevice" />
    <tizen:privilege name="http://tizen.org/privilege/internet" />
    <tizen:privilege name="http://tizen.org/privilege/power" />
    <tizen:privilege name="http://tizen.org/privilege/tv.inputdevice" />
    <access origin="*" subdomains="true" />
    <tizen:profile name="tv-samsung" />
    <tizen:setting screen-orientation="landscape" context-menu="disable" background-support="disable" encryption="disable" install-location="auto" hwkey-event="enable" />
</widget>
